{
  "name": "memorai",
  "version": "0.1.0",
  "description": "Runtime-agnostic multimodal streaming memory for AI agents — Browser, Node.js, Bun, Deno",
  "homepage": "https://github.com/Naeemo/memorai#readme",
  "bugs": {
    "url": "https://github.com/Naeemo/memorai/issues"
  },
  "license": "MIT",
  "author": "Naeemo <naeemo@qq.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Naeemo/memorai.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js"
    },
    "./embeddings": {
      "types": "./dist/embeddings/index.d.ts",
      "import": "./dist/embeddings/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "bumpp": "^10.4.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.21",
    "vitest": "^3.2.4"
  }
}
